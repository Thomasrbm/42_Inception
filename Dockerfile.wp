# Partir de l'image officielle WordPress avec FPM
FROM wordpress:php8.4-fpm

# Définir le répertoire de travail
WORKDIR /var/www/html

# Copier les thèmes ou plugins si nécessaire (optionnel)
# COPY custom-theme/ wp-content/themes/custom-theme/
# COPY custom-plugin/ wp-content/plugins/custom-plugin/

# Les fichiers WordPress sont déjà inclus dans l'image officielle FPM
# Expose le port FPM standard
EXPOSE 9000
